# AlphaQuant Terminal Configuration
# Copy this to .env and fill in your credentials

# ─────────────────────────────────────────────
# Market Settings
# ─────────────────────────────────────────────
DEFAULT_MARKET=Crypto
TRADING_DAYS_CRYPTO=365
TRADING_DAYS_INDIA=252

# ─────────────────────────────────────────────
# Technical Indicators - Default Parameters
# ─────────────────────────────────────────────
RSI_PERIOD=14
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2.0
ATR_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ─────────────────────────────────────────────
# Liquidity Sweep Settings
# ─────────────────────────────────────────────
SWEEP_DETECTION_WINDOW=20
SHOW_SWEEPS_DEFAULT=true

# ─────────────────────────────────────────────
# ML Model Settings
# ─────────────────────────────────────────────
ML_N_ESTIMATORS=150
ML_MAX_DEPTH=6
ML_RANDOM_STATE=42
ML_CALIBRATE=true
ML_TRAINING_PERIOD=2y
ML_MIN_DATA_POINTS=200

# ─────────────────────────────────────────────
# Hurst Exponent Settings
# ─────────────────────────────────────────────
HURST_MIN_DATA=100
HURST_MAX_LAG=200
HURST_N_LAGS=30
HURST_MIN_VALID_LAGS=8
HURST_R2_HIGH_THRESHOLD=0.97
HURST_R2_MEDIUM_THRESHOLD=0.90
HURST_TREND_THRESHOLD=0.58
HURST_MEAN_REV_THRESHOLD=0.42

# ─────────────────────────────────────────────
# Data Fetching Settings
# ─────────────────────────────────────────────
DATA_FETCH_RETRY_ATTEMPTS=3
DATA_FETCH_BACKOFF=1.5
DATA_CACHE_TTL_LIVE=300
DATA_CACHE_TTL_HISTORY=3600

# ─────────────────────────────────────────────
# Fyers API Settings (for real OI data)
# ─────────────────────────────────────────────
FYERS_API_ENABLED=false
FYERS_API_KEY=your_fyers_api_key_here
FYERS_API_SECRET=your_fyers_api_secret_here
FYERS_CLIENT_ID=your_client_id_here

# ─────────────────────────────────────────────
# Volatility Calculations
# ─────────────────────────────────────────────
IV_RANK_WINDOW=20
PARKINSON_PERIODS=252

# ─────────────────────────────────────────────
# Rolling Performance Metrics (ML)
# ─────────────────────────────────────────────
ROLLING_WINDOWS=[7,30,90]
ACCURACY_THRESHOLD=0.55
PRECISION_THRESHOLD=0.60
RECALL_THRESHOLD=0.60

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=alphaquant.log

# ─────────────────────────────────────────────
# UI/UX Settings
# ─────────────────────────────────────────────
DARK_MODE=true
CHART_HEIGHT_DEFAULT=700
CHART_HEIGHT_SMALL=420
